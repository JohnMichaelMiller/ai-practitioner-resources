# GitHub Gist Configuration
# Get your token from: https://github.com/settings/tokens
# Required scopes: gist
# Used by: fetch-current-resources.js, update-gist.js

# Production Gist (default)
GIST_ID=1a9d84d165a170d6f62cc052db97b8bb
GIST_TOKEN=your_github_personal_access_token_here

# Test Gist (used when TEST_MODE=true or running test:* scripts)
# Create a separate test gist at: https://gist.github.com/
TEST_GIST_ID=your_test_gist_id_here
TEST_GIST_TOKEN=your_github_personal_access_token_here

# Anthropic API Configuration (used by generate-resources.js)
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional model override for resource generation
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Optional generation temperature (lower = more deterministic)
AI_TEMPERATURE=0.2
# Optional target number of generated resources per run
TARGET_RESOURCE_COUNT=6

# OpenAI API Configuration (optional, used by pm-review.js)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here
